{
  "name": "option-sync",
  "version": "1.0.0",
  "description": "Manage and sync Minecraft Bedrock options.txt across multiple local accounts.",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:css": "tailwindcss -i ./public/tailwind.css -o ./public/styles.css --minify",
    "lint": "node --check src/server.js && node --check public/app.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "chokidar": "^4.0.3",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "multer": "^2.0.2",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "engines": {
    "node": ">=18"
  }
}
